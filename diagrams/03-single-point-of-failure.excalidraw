    {
      "type": "text",
      "id": "c3_text",
      "x": 604.1102905273438,
      "y": 654.0126037597656,
      "width": 220,
      "height": 120,
      "text": "Async vs Sync Replication\n\nAsync: быстрее, но\nможет потерять данные\nпри крэше\n\nSync: гарантирует,\nно тормозит writes",
      "originalText": "Async vs Sync Replication\n\nAsync: быстрее, но\nможет потерять данные\nпри крэше\n\nSync: гарантирует,\nно тормозит writes",
      "fontSize": 12,
      "fontFamily": 3,
      "textAlign": "center",
      "verticalAlign": "middle",
      "strokeColor": "#374151",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
